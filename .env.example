# Anthropic API key — optional. If unset, the AI deep-analysis layer
# is skipped and you get linguistic-only digests.
ANTHROPIC_API_KEY=

# Model to use. Default is the most capable; downgrade to claude-sonnet-4-6
# or claude-haiku-4-5-20251001 for cheaper runs.
ANTHROPIC_MODEL=claude-opus-4-7

# Logging level — DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
